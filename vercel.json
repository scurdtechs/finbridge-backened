{
  "version": 2,
  "builds": [
    {
      "src": "debug-server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/debug-server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/debug-server.js"
    }
  ],
  "env": {
    "NODE_VERSION": "24"
  }
}

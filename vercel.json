{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "env": {
    "NODE_VERSION": "24"
  },
  "functions": {
    "server.js": {
      "includeFiles": ["utils/**", "models/**", "middleware/**", "routes/**"],
      "excludeFiles": "node_modules/**"
    }
  }
}
